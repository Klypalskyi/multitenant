{
  "name": "@multitenant/site",
  "private": true,
  "description": "Public docs / landing — Next.js + Fumadocs (MDX, Tailwind 4).",
  "scripts": {
    "dev": "next dev --port 3101",
    "build": "next build",
    "start": "next start --port 3101",
    "test": "vitest run",
    "docs:patch-titles": "node ./scripts/patch-doc-titles.mjs",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit"
  },
  "license": "MIT",
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "fumadocs-core": "16.7.7",
    "fumadocs-mdx": "14.2.11",
    "fumadocs-ui": "16.7.7",
    "lucide-react": "^1.7.0",
    "mermaid": "^11.13.0",
    "next": "^16.1.7",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@multitenant/cli": "^0.5.3",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/mdx": "^2.0.13",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.4.0",
    "vitest": "3.2.4"
  }
}
