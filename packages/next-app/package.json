{
  "name": "@multitenant/next-app",
  "peerDependencies": {
    "next": ">=13.0.0"
  },
  "dependencies": {
    "@multitenant/config": "^0.4.0",
    "@multitenant/core": "^0.5.0"
  },
  "version": "0.5.0",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./auto": {
      "types": "./dist/auto.d.ts",
      "import": "./dist/auto.mjs",
      "require": "./dist/auto.js"
    },
    "./auto-node": {
      "types": "./dist/auto-node.d.ts",
      "import": "./dist/auto-node.mjs",
      "require": "./dist/auto-node.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/auto.ts src/auto-node.ts --format cjs,esm --dts",
    "test": "vitest run"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/klypalskyi/multitenant.git",
    "directory": "packages/next-app"
  },
  "bugs": {
    "url": "https://github.com/klypalskyi/multitenant/issues"
  },
  "homepage": "https://github.com/klypalskyi/multitenant/tree/master/packages/next-app",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "next": "^15.5.14",
    "vitest": "^3.0.5"
  }
}
